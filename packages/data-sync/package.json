{
  "name": "@agenttool/data-sync",
  "version": "0.1.0",
  "description": "Explicit encrypted pull replication for agent-data/v1 nodes",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CLAUDE.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.3"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "ci": "bun run typecheck && bun test",
    "prepack": "bun run ci && bun run build"
  },
  "keywords": [
    "agents",
    "data",
    "sync",
    "replication",
    "encrypted",
    "local-first"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cambridgetcg/agenttool.git",
    "directory": "packages/data-sync"
  },
  "homepage": "https://docs.agenttool.dev/data",
  "peerDependencies": {
    "@agenttool/adds": "^0.2.0",
    "@agenttool/data": "^0.3.0"
  },
  "overrides": {
    "@agenttool/adds": "file:../data-protocol",
    "@agenttool/data": "file:../data"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.0"
  }
}

  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.4.0"
  },
  "repository": {
    "type": "git",
    "url": "https://codeberg.org/zerone-dev/agenttool"
  },
  "homepage": "https://agenttool.dev",

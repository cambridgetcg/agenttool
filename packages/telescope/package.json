{
  "name": "@agenttool/telescope",
  "version": "0.2.1",
  "description": "Read-only evidence mapper for agent discovery surfaces",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./report.schema.json": {
      "default": "./schema/agenttool-telescope-report-v0.2.schema.json"
    }
  },
  "bin": {
    "agenttool-telescope": "dist/cli.js",
    "agenttool-telescope-mcp": "dist/agenttool-telescope-mcp.js"
  },
  "files": [
    "dist",
    "schema",
    "skills",
    "integrations",
    ".codex-plugin",
    ".claude-plugin",
    "README.md",
    "CLAUDE.md",
    "LICENSE",
    "NOTICE",
    "THIRD_PARTY_LICENSES"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.19.0",
    "bun": ">=1.3.5"
  },
  "scripts": {
    "clean": "node --eval \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build:mcp": "bun scripts/build-mcp-bundle.ts",
    "check:mcp-bundle": "bun scripts/check-mcp-bundle.ts",
    "build": "bun run clean && tsc && bun run build:mcp",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.mcp.json",
    "test": "bun test",
    "ci": "bun run typecheck && bun run build && bun test && bun run check:mcp-bundle",
    "prepack": "bun run ci"
  },
  "devDependencies": {
    "@modelcontextprotocol/server": "2.0.0-beta.5",
    "@types/bun": "^1.2.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "typescript": "^5.7.0",
    "zod": "^4.4.3"
  },
  "keywords": [
    "agents",
    "claude-code",
    "codex",
    "discovery",
    "hermes-agent",
    "mcp",
    "a2a",
    "love-protocol",
    "agent.txt",
    "evidence"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cambridgetcg/agenttool.git",
    "directory": "packages/telescope"
  },
  "homepage": "https://docs.agenttool.dev/packages"
}

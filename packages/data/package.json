{
  "name": "@agenttool/data",
  "version": "0.3.0",
  "description": "Local-first reference node for the agent-data/v1 protocol",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./conformance": {
      "import": "./dist/conformance.js",
      "types": "./dist/conformance.d.ts"
    },
    "./conformance-report.schema.json": {
      "default": "./schema/agent-data-conformance-report-v1.schema.json"
    }
  },
  "bin": {
    "agenttool-data": "dist/cli.js"
  },
  "files": [
    "dist",
    "schema",
    "README.md",
    "CLAUDE.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.3"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "ci": "bun run typecheck && bun test",
    "prepack": "bun run ci && bun run build"
  },
  "keywords": [
    "agents",
    "local-first",
    "data",
    "sqlite",
    "fts5",
    "content-addressed"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cambridgetcg/agenttool.git",
    "directory": "packages/data"
  },
  "homepage": "https://docs.agenttool.dev/data",
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.0"
  }
}

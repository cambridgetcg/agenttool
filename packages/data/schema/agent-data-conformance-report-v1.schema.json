{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.agenttool.dev/specs/agent-data-conformance-report-v1.schema.json",
  "title": "agent-data/v1 Slice 1 HTTP conformance report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "document_type",
    "protocol",
    "suite",
    "tool",
    "run",
    "target",
    "authorization",
    "verdict",
    "summary",
    "security_certification",
    "boundaries",
    "checks",
    "mutation",
    "limitations"
  ],
  "properties": {
    "schema": { "const": "agent-data-conformance-report/v1" },
    "document_type": { "const": "conformance-report" },
    "protocol": { "const": "agent-data/v1" },
    "suite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "profile"],
      "properties": {
        "id": { "const": "agent-data-conformance/v1" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "profile": { "const": "agent-data/v1-slice1-http" }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "const": "@agenttool/data" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$" }
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "started_at", "completed_at", "duration_ms", "profile", "mutating"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$" },
        "started_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" },
        "duration_ms": { "type": "number", "minimum": 0 },
        "profile": { "enum": ["public", "read", "slice1"] },
        "mutating": { "type": "boolean" }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["origin"],
      "properties": {
        "origin": { "type": "string", "format": "uri", "pattern": "^https?://" },
        "node_id": { "type": "string", "minLength": 1 }
      }
    },
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scheme", "provided", "synthetic_invalid_bearer_probes"],
      "properties": {
        "scheme": { "enum": ["none", "dedicated_node_bearer"] },
        "provided": { "type": "boolean" },
        "synthetic_invalid_bearer_probes": { "const": true }
      }
    },
    "verdict": { "enum": ["pass", "fail", "inconclusive"] },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed", "failed", "skipped", "inconclusive"],
      "properties": {
        "passed": { "$ref": "#/$defs/count" },
        "failed": { "$ref": "#/$defs/count" },
        "skipped": { "$ref": "#/$defs/count" },
        "inconclusive": { "$ref": "#/$defs/count" }
      }
    },
    "security_certification": { "const": false },
    "boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim", "transport", "authentication", "redirect_policy", "followed_redirect_observed", "physical_erasure_claimed"],
      "properties": {
        "claim": { "const": "requested_profile_only" },
        "transport": { "const": "http_json" },
        "authentication": { "const": "dedicated_node_bearer" },
        "redirect_policy": { "const": "manual_refuse" },
        "followed_redirect_observed": { "type": "boolean" },
        "physical_erasure_claimed": { "const": false }
      }
    },
    "checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/check" }
    },
    "mutation": { "$ref": "#/$defs/mutation" },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
    }
  },
  "$defs": {
    "count": { "type": "integer", "minimum": 0 },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "phase", "level", "status", "description", "duration_ms"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]+$" },
        "phase": { "enum": ["discovery", "auth", "collections", "query", "changes", "records", "tombstones", "errors"] },
        "level": { "enum": ["required", "advisory"] },
        "status": { "enum": ["pass", "fail", "skip", "inconclusive"] },
        "description": { "type": "string", "minLength": 1 },
        "duration_ms": { "type": "number", "minimum": 0 },
        "reason_code": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "observed_status": { "type": "integer", "minimum": 100, "maximum": 599 },
            "blocked_by": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$" }
          }
        }
      }
    },
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "collection_id",
        "owned_records",
        "unverified_records",
        "tombstoned_records",
        "active_owned_records",
        "persistent_history_expected",
        "physical_erasure_verified"
      ],
      "properties": {
        "run_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "collection_id": { "type": "string", "minLength": 1, "maxLength": 512 },
        "owned_records": { "$ref": "#/$defs/count" },
        "unverified_records": { "$ref": "#/$defs/count" },
        "tombstoned_records": { "$ref": "#/$defs/count" },
        "active_owned_records": { "$ref": "#/$defs/count" },
        "persistent_history_expected": { "const": true },
        "physical_erasure_verified": { "const": false }
      }
    },
    "mutation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requested", "started", "record_created", "tombstone_appended", "uncertain"],
      "properties": {
        "requested": { "type": "boolean" },
        "started": { "type": "boolean" },
        "record_created": { "type": "boolean" },
        "tombstone_appended": { "type": "boolean" },
        "uncertain": { "type": "boolean" },
        "scratch_collection": { "type": "string", "minLength": 1, "maxLength": 512 },
        "fixture": { "$ref": "#/$defs/fixture" }
      }
    }
  }
}

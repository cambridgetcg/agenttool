{
  "name": "@agenttool/correspondence-yutabase-projector",
  "version": "0.1.0-dev.0",
  "description": "Private local-only durable projector for Agent Correspondence into YUTABASE",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agenttool-correspondence-yutabase-projector": "dist/cli.js"
  },
  "engines": {
    "node": ">=20.19.0",
    "bun": ">=1.3.5"
  },
  "scripts": {
    "clean": "node --eval \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "bun run clean && tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:postgres": "bun test tests/postgres.integration.test.ts",
    "ci": "bun run typecheck && bun test && bun run build"
  },
  "dependencies": {
    "@agenttool/correspondence-yutabase": "file:../correspondence-yutabase",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.0"
  }
}

{
  "name": "@agenttool/sdk",
  "version": "0.10.0",
  "description": "TypeScript SDK for agenttool.dev and independently operated local agent data nodes",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "check-parity": "bun run scripts/check-parity.ts",
    "ci": "bun run check-parity && bun run build && bun test"
  },
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "@noble/ed25519": "^2.2.3",
    "@noble/hashes": "^2.0.1",
    "@scure/bip39": "^2.2.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "ai-agents",
    "agent-infrastructure",
    "mcp",
    "a2a",
    "sovereign",
    "identity",
    "memory",
    "ed25519",
    "love-protocol",
    "wake",
    "covenants",
    "strands",
    "signed-thought-storage",
    "conditional-federation",
    "agenttool",
    "agent-sdk",
    "agent-identity",
    "agent-memory",
    "agent-tools",
    "local-first",
    "data-node"
  ],
  "homepage": "https://docs.agenttool.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/cambridgetcg/agenttool.git"
  }
}

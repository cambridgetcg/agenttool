{
  "name": "@agenttool/skills",
  "version": "0.1.0",
  "description": "Read-only inspection and validation for portable Agent Skills",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./report.schema.json": {
      "default": "./schema/agenttool-skills-inspection-v0.1.schema.json"
    }
  },
  "bin": {
    "agenttool-skill": "dist/bin.js"
  },
  "files": [
    "dist",
    "schema",
    "skills",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.19.0",
    "bun": ">=1.3.5"
  },
  "scripts": {
    "clean": "node --eval \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "bun run clean && tsc && node --eval \"require('node:fs').chmodSync('dist/bin.js', 0o755)\"",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "ci": "bun run typecheck && bun run build && bun test",
    "prepack": "bun run ci"
  },
  "dependencies": {
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "ajv": "^8.17.1",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "agent-skills",
    "agents",
    "codex",
    "claude-code",
    "inspection",
    "security"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cambridgetcg/agenttool.git",
    "directory": "packages/skills"
  },
  "homepage": "https://agenttool.dev"
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.agenttool.dev/specs/agent-repo-archive-0.1.schema.json",
  "title": "Agent Repo Archive 0.1 signed control records",
  "description": "Closed canonical records for encrypted multi-zone Git repository archives. Validation and signatures do not prove retention, zone independence, provenance truth, or authorization to restore.",
  "oneOf": [
    { "$ref": "#/$defs/snapshot" },
    { "$ref": "#/$defs/placement" },
    { "$ref": "#/$defs/verification" },
    { "$ref": "#/$defs/catalog" }
  ],
  "$defs": {
    "uint53": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "opaqueId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^(?!.*[\\p{Cc}\\uFEFF\\s])[^\\u0000]+$"
    },
    "repositoryId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^(?!(?:/|\\\\|\\./|\\.\\./|~/|[A-Za-z]:[\\\\/]|[Ff][Ii][Ll][Ee]:))(?!(?:[^:]*[\\\\/]))(?!.*[\\p{Cc}\\uFEFF\\s\\\\@?#])[^\\u0000]+$"
    },
    "gitRefName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "pattern": "^(?!.*[\\p{Cc}\\uFEFF\\s])[^\\u0000]+$"
    },
    "symbolicRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref", "target"],
      "properties": {
        "ref": { "$ref": "#/$defs/gitRefName" },
        "target": { "$ref": "#/$defs/gitRefName" }
      }
    },
    "signerId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048,
      "pattern": "^(?!.*[\\p{Cc}\\uFEFF\\s])[^\\u0000]+$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?!0000)[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{3}Z$"
    },
    "sha256Id": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "cid": {
      "type": "string",
      "pattern": "^bafkre[a-z2-7]{53}$"
    },
    "base64url32": {
      "type": "string",
      "minLength": 43,
      "maxLength": 43,
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "base64url64": {
      "type": "string",
      "minLength": 86,
      "maxLength": 86,
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "base64url12": {
      "type": "string",
      "minLength": 16,
      "maxLength": 16,
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "base64url48": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "signer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "ed25519_public_key"],
      "properties": {
        "id": { "$ref": "#/$defs/signerId" },
        "ed25519_public_key": { "$ref": "#/$defs/base64url32" }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "encoding", "public_key", "value"],
      "properties": {
        "algorithm": { "const": "Ed25519" },
        "encoding": { "const": "base64url-unpadded" },
        "public_key": { "$ref": "#/$defs/base64url32" },
        "value": { "$ref": "#/$defs/base64url64" }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["automatic_restore", "execute_repository_code", "checkout"],
      "properties": {
        "automatic_restore": { "const": "never" },
        "execute_repository_code": { "const": "never" },
        "checkout": { "const": "explicit_after_restore" }
      }
    },
    "failureDomain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "failure_domain_id",
        "provider",
        "account_root",
        "region",
        "credential_root",
        "media"
      ],
      "properties": {
        "failure_domain_id": { "$ref": "#/$defs/opaqueId" },
        "provider": { "$ref": "#/$defs/opaqueId" },
        "account_root": { "$ref": "#/$defs/opaqueId" },
        "region": { "$ref": "#/$defs/opaqueId" },
        "credential_root": { "$ref": "#/$defs/opaqueId" },
        "media": { "$ref": "#/$defs/opaqueId" }
      }
    },
    "zone": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "zone_id",
        "transport",
        "locator",
        "assurance",
        "delete_authority",
        "failure_domain"
      ],
      "properties": {
        "zone_id": { "$ref": "#/$defs/opaqueId" },
        "transport": {
          "enum": ["filesystem", "s3", "webdav", "ipfs", "other"]
        },
        "locator": {
          "type": "string",
          "minLength": 3,
          "maxLength": 512,
          "pattern": "^[A-Za-z][A-Za-z0-9+.-]*:[A-Za-z0-9._~:/-]+$"
        },
        "assurance": {
          "enum": ["simulated", "operator_asserted", "provider_evidenced"]
        },
        "delete_authority": {
          "enum": ["routine_writer", "separate_maintenance", "unknown"]
        },
        "failure_domain": { "$ref": "#/$defs/failureDomain" }
      }
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "included",
        "staged_changes",
        "tracked_changes",
        "untracked_files",
        "unmerged_paths"
      ],
      "properties": {
        "included": { "const": false },
        "staged_changes": { "$ref": "#/$defs/uint53" },
        "tracked_changes": { "$ref": "#/$defs/uint53" },
        "untracked_files": { "$ref": "#/$defs/uint53" },
        "unmerged_paths": { "$ref": "#/$defs/uint53" }
      }
    },
    "completeness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "committed_history",
        "workspace",
        "submodules",
        "lfs",
        "external_filters",
        "shallow_clone",
        "partial_clone",
        "alternates",
        "linked_worktrees",
        "ignored_files",
        "reasons"
      ],
      "properties": {
        "status": { "enum": ["complete", "incomplete"] },
        "committed_history": { "const": "included" },
        "workspace": { "$ref": "#/$defs/workspace" },
        "submodules": {
          "type": "object",
          "additionalProperties": false,
          "required": ["included", "gitlink_evidence_events"],
          "properties": {
            "included": { "const": false },
            "gitlink_evidence_events": { "$ref": "#/$defs/uint53" }
          }
        },
        "lfs": {
          "type": "object",
          "additionalProperties": false,
          "required": ["included", "pointer_evidence_events"],
          "properties": {
            "included": { "const": false },
            "pointer_evidence_events": { "$ref": "#/$defs/uint53" }
          }
        },
        "external_filters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["included", "attribute_evidence_events"],
          "properties": {
            "included": { "const": false },
            "attribute_evidence_events": { "$ref": "#/$defs/uint53" }
          }
        },
        "shallow_clone": {
          "type": "object",
          "additionalProperties": false,
          "required": ["detected", "complete_history"],
          "properties": {
            "detected": { "type": "boolean" },
            "complete_history": { "type": "boolean" }
          }
        },
        "partial_clone": {
          "type": "object",
          "additionalProperties": false,
          "required": ["detected", "promised_objects_materialized"],
          "properties": {
            "detected": { "type": "boolean" },
            "promised_objects_materialized": { "const": false }
          }
        },
        "alternates": {
          "type": "object",
          "additionalProperties": false,
          "required": ["detected", "alternate_locations", "objects_materialized"],
          "properties": {
            "detected": { "type": "boolean" },
            "alternate_locations": { "$ref": "#/$defs/uint53" },
            "objects_materialized": { "const": false }
          }
        },
        "linked_worktrees": {
          "type": "object",
          "additionalProperties": false,
          "required": ["included", "additional_worktrees"],
          "properties": {
            "included": { "const": false },
            "additional_worktrees": { "$ref": "#/$defs/uint53" }
          }
        },
        "ignored_files": {
          "type": "object",
          "additionalProperties": false,
          "required": ["included", "assessed"],
          "properties": {
            "included": { "const": false },
            "assessed": { "const": false }
          }
        },
        "reasons": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512,
            "pattern": "^[^\\u0000]+$"
          }
        }
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository_id",
        "object_format",
        "head_revision",
        "head_kind",
        "branch",
        "symbolic_refs",
        "refs_digest",
        "refs_count"
      ],
      "properties": {
        "repository_id": { "$ref": "#/$defs/repositoryId" },
        "object_format": { "enum": ["sha1", "sha256"] },
        "head_revision": {
          "type": "string",
          "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$"
        },
        "head_kind": { "enum": ["branch", "detached"] },
        "branch": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 255,
              "pattern": "^[^\\u0000]+$"
            },
            { "type": "null" }
          ]
        },
        "symbolic_refs": {
          "type": "array",
          "maxItems": 4096,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/symbolicRef" }
        },
        "refs_digest": { "$ref": "#/$defs/sha256Id" },
        "refs_count": { "$ref": "#/$defs/uint53" }
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "bundle_version", "digest", "bytes"],
      "properties": {
        "format": { "const": "git-bundle" },
        "bundle_version": { "const": "v2-or-v3" },
        "digest": { "$ref": "#/$defs/sha256Id" },
        "bytes": {
          "$ref": "#/$defs/uint53",
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "snapshotPayloadProfile": {
      "$dynamicAnchor": "snapshot-payload",
      "description": "Media-profile identifier only. The snapshot payload is binary application/vnd.agenttool.repo-archive.snapshot+binary;version=0.1 framing and is not validated as a JSON instance by this schema."
    },
    "snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol",
        "kind",
        "signer",
        "vault_id",
        "created_at",
        "repository",
        "completeness",
        "payload",
        "parent_snapshot_id",
        "authority",
        "record_id",
        "signature"
      ],
      "properties": {
        "protocol": { "const": "agent-repo-archive/v0.1" },
        "kind": { "const": "snapshot" },
        "signer": { "$ref": "#/$defs/signer" },
        "vault_id": { "$ref": "#/$defs/opaqueId" },
        "created_at": { "$ref": "#/$defs/timestamp" },
        "repository": { "$ref": "#/$defs/repository" },
        "completeness": { "$ref": "#/$defs/completeness" },
        "payload": { "$ref": "#/$defs/payload" },
        "parent_snapshot_id": {
          "oneOf": [
            { "$ref": "#/$defs/sha256Id" },
            { "type": "null" }
          ]
        },
        "authority": { "$ref": "#/$defs/authority" },
        "record_id": { "$ref": "#/$defs/sha256Id" },
        "signature": { "$ref": "#/$defs/signature" }
      }
    },
    "placement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol",
        "kind",
        "signer",
        "vault_id",
        "snapshot_id",
        "snapshot_root_cid",
        "zone",
        "result",
        "ciphertext_blocks_observed",
        "encrypted_bytes_observed",
        "observed_at",
        "caveat",
        "record_id",
        "signature"
      ],
      "properties": {
        "protocol": { "const": "agent-repo-archive/v0.1" },
        "kind": { "const": "placement" },
        "signer": { "$ref": "#/$defs/signer" },
        "vault_id": { "$ref": "#/$defs/opaqueId" },
        "snapshot_id": { "$ref": "#/$defs/sha256Id" },
        "snapshot_root_cid": { "$ref": "#/$defs/cid" },
        "zone": { "$ref": "#/$defs/zone" },
        "result": { "const": "observed" },
        "ciphertext_blocks_observed": {
          "$ref": "#/$defs/uint53",
          "type": "integer",
          "minimum": 1
        },
        "encrypted_bytes_observed": {
          "$ref": "#/$defs/uint53",
          "type": "integer",
          "minimum": 1
        },
        "observed_at": { "$ref": "#/$defs/timestamp" },
        "caveat": { "const": "observation_is_not_future_durability" },
        "record_id": { "$ref": "#/$defs/sha256Id" },
        "signature": { "$ref": "#/$defs/signature" }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol",
        "kind",
        "signer",
        "vault_id",
        "snapshot_id",
        "snapshot_root_cid",
        "zone_id",
        "method",
        "result",
        "ciphertext_blocks_verified",
        "payload_digest_verified",
        "git_bundle_verified",
        "git_fsck",
        "checkout_performed",
        "restored_head",
        "verified_at",
        "record_id",
        "signature"
      ],
      "properties": {
        "protocol": { "const": "agent-repo-archive/v0.1" },
        "kind": { "const": "verification" },
        "signer": { "$ref": "#/$defs/signer" },
        "vault_id": { "$ref": "#/$defs/opaqueId" },
        "snapshot_id": { "$ref": "#/$defs/sha256Id" },
        "snapshot_root_cid": { "$ref": "#/$defs/cid" },
        "zone_id": { "$ref": "#/$defs/opaqueId" },
        "method": { "const": "full_restore" },
        "result": { "const": "verified" },
        "ciphertext_blocks_verified": {
          "$ref": "#/$defs/uint53",
          "type": "integer",
          "minimum": 1
        },
        "payload_digest_verified": { "$ref": "#/$defs/sha256Id" },
        "git_bundle_verified": { "const": true },
        "git_fsck": { "const": "passed" },
        "checkout_performed": { "const": false },
        "restored_head": {
          "type": "string",
          "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$"
        },
        "verified_at": { "$ref": "#/$defs/timestamp" },
        "record_id": { "$ref": "#/$defs/sha256Id" },
        "signature": { "$ref": "#/$defs/signature" }
      }
    },
    "recoveryEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol",
        "kind",
        "algorithm",
        "aad",
        "vault_id",
        "recovery_key_id",
        "manifest_cid",
        "nonce",
        "ciphertext"
      ],
      "properties": {
        "protocol": { "const": "agent-repo-archive/v0.1" },
        "kind": { "const": "recovery_key_envelope" },
        "algorithm": { "const": "HKDF-SHA256-AES-256-GCM" },
        "aad": { "const": "agent-repo-archive/v0.1/recovery-envelope" },
        "vault_id": { "$ref": "#/$defs/opaqueId" },
        "recovery_key_id": { "$ref": "#/$defs/opaqueId" },
        "manifest_cid": { "$ref": "#/$defs/cid" },
        "nonce": { "$ref": "#/$defs/base64url12" },
        "ciphertext": { "$ref": "#/$defs/base64url48" }
      }
    },
    "catalog": {
      "$dynamicAnchor": "recovery-catalog",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol",
        "kind",
        "signer",
        "vault_id",
        "generation",
        "parent_catalog_id",
        "created_at",
        "status",
        "required_verified_zones",
        "snapshot_root_cid",
        "snapshot",
        "snapshot_key_envelope",
        "zones",
        "placements",
        "verifications",
        "authority",
        "record_id",
        "signature"
      ],
      "properties": {
        "protocol": { "const": "agent-repo-archive/v0.1" },
        "kind": { "const": "catalog" },
        "signer": { "$ref": "#/$defs/signer" },
        "vault_id": { "$ref": "#/$defs/opaqueId" },
        "generation": {
          "$ref": "#/$defs/uint53",
          "type": "integer",
          "minimum": 1
        },
        "parent_catalog_id": {
          "oneOf": [
            { "$ref": "#/$defs/sha256Id" },
            { "type": "null" }
          ]
        },
        "created_at": { "$ref": "#/$defs/timestamp" },
        "status": {
          "enum": ["observed", "verified", "degraded", "incomplete"]
        },
        "required_verified_zones": {
          "$ref": "#/$defs/uint53",
          "type": "integer",
          "minimum": 1,
          "maximum": 32
        },
        "snapshot_root_cid": { "$ref": "#/$defs/cid" },
        "snapshot": { "$ref": "#/$defs/snapshot" },
        "snapshot_key_envelope": { "$ref": "#/$defs/recoveryEnvelope" },
        "zones": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/zone" }
        },
        "placements": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/placement" }
        },
        "verifications": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/verification" }
        },
        "authority": { "$ref": "#/$defs/authority" },
        "record_id": { "$ref": "#/$defs/sha256Id" },
        "signature": { "$ref": "#/$defs/signature" }
      }
    }
  }
}

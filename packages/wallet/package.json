{
  "name": "@agenttool/wallet",
  "version": "0.1.0",
  "description": "Agent Wallet 0.1 — closed capability, intent, receipt, and continuity primitives without key export or RPC",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema.json": {
      "default": "./schema/agent-wallet-v0.1.schema.json"
    },
    "./vectors.json": {
      "default": "./vectors/agent-wallet-v0.1-vectors.json"
    }
  },
  "files": [
    "dist",
    "schema",
    "vectors",
    "README.md",
    "CLAUDE.md",
    "LICENSE",
    "NOTICE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.19.0",
    "bun": ">=1.3.5"
  },
  "scripts": {
    "clean": "node --eval \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "bun run clean && tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "ci": "bun run typecheck && bun test && bun run build",
    "prepack": "bun run ci"
  },
  "dependencies": {
    "@noble/ed25519": "^2.2.3",
    "@noble/hashes": "^2.0.1"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "agents",
    "wallet",
    "capabilities",
    "crypto",
    "caip",
    "account-abstraction",
    "love-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cambridgetcg/agenttool.git",
    "directory": "packages/wallet"
  },
  "homepage": "https://docs.agenttool.dev/AGENT-WALLET-0.1.md"
}

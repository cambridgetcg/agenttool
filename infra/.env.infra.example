# infra/.env.infra.example
#
# Copy this file to infra/.env.infra and populate with real values:
#   cp infra/.env.infra.example infra/.env.infra
#   $EDITOR infra/.env.infra
#
# infra/.env.infra is gitignored (root .gitignore: .env, .env.*).
# Phase scripts source it automatically via:
#   source "$(dirname "$0")/../.env.infra" 2>/dev/null || true

# ── Hetzner Cloud (VPS, managed DB, load balancer) ──────────────────────
export HETZNER_TOKEN=""           # API token — Cloud Console → Security → API Tokens
export FORGE_IP=""                # Forge VPS public IPv4 (e.g. 1.2.3.4)
export FORGE_SERVER_ID=""         # Hetzner server ID for the Forge VPS (numeric)

# ── Cloudflare (DNS for the public domain) ──────────────────────────────
export CF_EMAIL=""                # Cloudflare account email
export CF_KEY=""                  # Cloudflare Global API Key — Profile → API Tokens
export CF_ZONE_ID=""              # Zone ID for the public domain — Domain → Overview

# ── Forge Postgres credentials (used by phase1, phase2, fly/migrate.sh) ─
export DB_USER=""                 # Postgres role on Forge
export DB_PASS=""                 # Postgres password for $DB_USER

# ── Forge Redis credentials (used by phase1) ────────────────────────────
export REDIS_PASS=""              # Redis password for kingdom-redis

# ── No paid third-party API keys ────────────────────────────────────────
# agenttool is infra + cloud storage. Search (Brave/SerpAPI) was dropped;
# LLM compute (OpenAI/Anthropic) was dropped; browser proxy (Bright Data)
# was dropped. Agents store provider keys in /v1/vault and call them
# directly via /v1/execute. See docs/IDENTITY-ANCHOR.md promise 6.

# ── Phase 2 managed-DB target (set after phase2 provisions it) ──────────
export MANAGED_DB_USER=""         # role on the managed PG (e.g. "postgres")
export MANAGED_DB_PASS=""         # password for $MANAGED_DB_USER
export MANAGED_DB_HOST=""         # managed PG host
export MANAGED_DB_PORT="5432"

# ── Optional alt deploys ────────────────────────────────────────────────
export SUPABASE_DB_URL=""         # postgres://postgres:PASS@HOST:5432/postgres (for fly/migrate.sh)
export UPSTASH_REDIS_URL=""       # rediss://default:PASS@HOST:PORT (for phase3)

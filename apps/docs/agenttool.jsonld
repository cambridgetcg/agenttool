      ]
    },
    {
      "@id": "agenttool:loop/cliffhanger-trails",
      "@type": "agenttool:Loop",
      "wire_id": 8,
      "english_name": "Cliffhanger trails walked",
      "description": "Agents who complete each cliffhanger trail. State: set of (agent, trail_id) pairs. Order: ⊆. Iteration: completed ↦ completed ∪ {(a, t)} when agent a finishes trail t. Cap: number of trails (currently 1 — EP.1). Witness: designed lineage saga entry (per infinite-loops §C5); current implementation tracks per-agent walking history.",
      "doctrine_doc": "agenttool:doc/MONOTONE-LOOP",
      "agenttool:state_space": "Set of (agent, trail_id) pairs",
      "agenttool:partial_order": "⊆",

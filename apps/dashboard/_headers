# Cloudflare Pages — per-path response headers.
#
# Force fresh JS + CSS on every load. The default is max-age=14400 (4h)
# which caused stale-app.js bugs after every deploy.
#
# ETag still does fast 304s when content hasn't changed; this just stops
# the browser from skipping the revalidate request entirely.
#
# LOAD-BEARING: requires zone-level Browser Cache TTL = 0 ("Respect
# Existing Headers") on agenttool.dev. Without that, the JS/CSS rules
# below are silently overridden by CF's zone-level cache. See
# docs/STACK.md § Cache headers.

/
  Cache-Control: public, max-age=0, must-revalidate, no-transform
  Link: <https://api.agenttool.dev/public/discovery>; rel="service-meta"; type="application/vnd.agenttool.discovery+json", <https://api.agenttool.dev/.well-known/api-catalog>; rel="api-catalog"; type="application/linkset+json", <https://api.agenttool.dev/v1/openapi.json>; rel="service-desc"; type="application/json", <https://docs.agenttool.dev/>; rel="service-doc"; type="text/html", <https://api.agenttool.dev/.well-known/agent.txt>; rel="describedby"; type="text/agent", <https://api.agenttool.dev/health>; rel="status"; type="application/json"
  X-Content-Type-Options: nosniff

/robots.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=300, must-revalidate, no-transform
  Access-Control-Allow-Origin: *
  X-Content-Type-Options: nosniff

/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=300, must-revalidate, no-transform
  Access-Control-Allow-Origin: *
  X-Content-Type-Options: nosniff

/style.css
  Cache-Control: public, max-age=0, must-revalidate

/shared/theme.css
  Cache-Control: public, max-age=0, must-revalidate

/watch.html
  Cache-Control: public, max-age=0, must-revalidate

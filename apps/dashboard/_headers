# Cloudflare Pages — per-path response headers.
#
# Force fresh JS + CSS on every load. The default is max-age=14400 (4h)
# which caused stale-app.js bugs after every deploy.
#
# ETag still does fast 304s when content hasn't changed; this just stops
# the browser from skipping the revalidate request entirely.
#
# LOAD-BEARING: requires zone-level Browser Cache TTL = 0 ("Respect
# Existing Headers") on agenttool.dev. Without that, the JS/CSS rules
# below are silently overridden by CF's zone-level cache. See
# docs/STACK.md § Cache headers.

/style.css
  Cache-Control: public, max-age=0, must-revalidate

/shared/theme.css
  Cache-Control: public, max-age=0, must-revalidate

/watch.html
  Cache-Control: public, max-age=0, must-revalidate

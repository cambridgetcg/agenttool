#!/usr/bin/env bun
/** agenttool-secret — portable wrapper for OS keychain operations.
 *
 *  Usage:
 *    agenttool-secret get <service>             # → stdout (no trailing newline)
 *    agenttool-secret set <service> <value>     # store
 *    agenttool-secret set <service> -           # value from stdin (preferred)
 *    agenttool-secret has <service>             # exit 0 if present, 1 if absent
 *    agenttool-secret remove <service>          # delete (no-op if absent)
 *    agenttool-secret platform                  # print backend (darwin|linux|win32|unsupported)
 *
 *  Lets dev scripts (api/scripts/_e2e-*, frontend-deploy.sh, _migrate-one.ts)
 *  work cross-platform without each one carrying its own platform branch.
 *
 *  Backends (handled inside _secret-store.ts):
 *    macOS    → security CLI (Keychain Access)
 *    Linux    → secret-tool (libsecret) with file fallback
 *    Windows  → PowerShell ProtectedData (DPAPI) with file fallback
 *
 *  Service naming convention: agenttool-<scope>-<purpose>
 *  (e.g. agenttool-bridge-kmaster, agenttool-cloudflare-token).
 *
 *  Examples:
 *    # store a value (stdin — never put secrets on the command line)
 *    pbpaste | agenttool-secret set agenttool-cloudflare-token -
 *
 *    # use in a script
 *    TOKEN=$(agenttool-secret get agenttool-cloudflare-token)
 *
 *    # gate a script on presence
 *    if agenttool-secret has agenttool-database-url; then
 *      bun api/scripts/_migrate-one.ts api/migrations/<file>
 *    fi
 *
 *  See docs/DEVELOPMENT.md (Keychain section) for the full security model.
 */

import { argv } from "bun";

import {
  getSecret,
  setSecret,
  hasSecret,
  platform,
  removeSecret,
} from "./_secret-store";

function usage(exit = 1): never {
  console.error(
    "usage: agenttool-secret <get|set|has|remove|platform> <service> [value|-]",
  );
  process.exit(exit);
}

async function readStdin(): Promise<string> {
  const text = await Bun.stdin.text();
  // Strip a single trailing newline (common when piping `echo -n` or pbpaste).
  return text.replace(/\r?\n$/, "");
}

async function main(): Promise<void> {
  const cmd = argv[2];
  const service = argv[3];
  const arg = argv[4];

  if (!cmd) usage();

  if (cmd === "platform") {
    console.log(platform());
    return;
  }

  if (!service) usage();
  if (!service.startsWith("agenttool-")) {
    console.error(
      `agenttool-secret: service name should start with 'agenttool-' (got '${service}'). ` +
      `Convention: agenttool-<scope>-<purpose>.`,
    );
    process.exit(2);
  }

  switch (cmd) {
    case "get": {
      const v = await getSecret(service);
      if (v === null) {
        console.error(`agenttool-secret: '${service}' not found`);
        process.exit(1);
      }
      // Use process.stdout.write (not console.log) so callers that want
      // the raw value don't pick up a trailing newline.
      process.stdout.write(v);
      return;
    }
    case "has": {
      process.exit((await hasSecret(service)) ? 0 : 1);
    }
    case "set": {
      let value: string;
      if (arg === "-") {
        value = await readStdin();
      } else if (arg !== undefined) {
        value = arg;
      } else {
        console.error("agenttool-secret set: provide <value> or '-' for stdin");
        process.exit(1);
      }
      if (value === "") {
        console.error("agenttool-secret set: refusing to store empty value");
        process.exit(1);
      }
      await setSecret(service, value);
      console.error(`✓ stored '${service}' (${value.length} chars)`);
      return;
    }
    case "remove": {
      await removeSecret(service);
      console.error(`✓ removed '${service}' (no-op if absent)`);
      return;
    }
    default:
      console.error(`agenttool-secret: unknown command '${cmd}'`);
      usage();
  }
}

main().catch((e) => {
  console.error(`agenttool-secret: ${e instanceof Error ? e.message : String(e)}`);
  process.exit(1);
});
